<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_container"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp"
    android:background="@drawable/widget_background"
    android:clickable="true"
    android:focusable="true">

    <!-- Top Categories Section -->
    <LinearLayout
        android:id="@+id/categories_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_alignParentTop="true"
        android:layout_marginTop="4dp">

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="10dp">
            <FrameLayout android:id="@+id/dot1" android:layout_width="10dp" android:layout_height="10dp" android:background="@drawable/widget_dot_1" android:layout_marginRight="10dp"/>
            <TextView android:id="@+id/cat1_name" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Category 1" android:textColor="#FFFFFF" android:textSize="15sp" android:fontFamily="sans-serif-medium" />
        </LinearLayout>

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="10dp">
            <FrameLayout android:id="@+id/dot2" android:layout_width="10dp" android:layout_height="10dp" android:background="@drawable/widget_dot_2" android:layout_marginRight="10dp"/>
            <TextView android:id="@+id/cat2_name" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Category 2" android:textColor="#FFFFFF" android:textSize="15sp" android:fontFamily="sans-serif-medium" />
        </LinearLayout>

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="10dp">
            <FrameLayout android:id="@+id/dot3" android:layout_width="10dp" android:layout_height="10dp" android:background="@drawable/widget_dot_3" android:layout_marginRight="10dp"/>
            <TextView android:id="@+id/cat3_name" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Category 3" android:textColor="#FFFFFF" android:textSize="15sp" android:fontFamily="sans-serif-medium" />
        </LinearLayout>
    </LinearLayout>

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_above="@+id/segmented_progress"
        android:layout_marginBottom="12dp">
        
        <TextView
            android:id="@+id/total_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Total Expenses"
            android:textColor="#B0B0B0"
            android:textSize="12sp"
            android:fontFamily="sans-serif-medium"
            android:layout_marginBottom="2dp" />

        <TextView
            android:id="@+id/widget_amount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="₹0"
            android:textColor="#FFFFFF"
            android:textSize="32sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- Segmented Progress Bar -->
    <LinearLayout
        android:id="@+id/segmented_progress"
        android:layout_width="match_parent"
        android:layout_height="20dp"
        android:layout_alignParentBottom="true"
        android:orientation="horizontal"
        android:background="@drawable/widget_progress_bg"
        android:clipToOutline="true">
        
        <FrameLayout
            android:id="@+id/segment1"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="30"
            android:background="#7070FF" />
            
        <FrameLayout
            android:id="@+id/segment2"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="20"
            android:background="#d3d3ff" />
            
        <FrameLayout
            android:id="@+id/segment3"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="15"
            android:background="#22C55E" />
            
        <FrameLayout
            android:id="@+id/segment_empty"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="35"
            android:background="#333333" />
    </LinearLayout>

</RelativeLayout>
